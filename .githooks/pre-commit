#!/usr/bin/env sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
sync_script="$repo_root/sync_web_assets.ps1"
trigger_script="$repo_root/update_pages_redeploy_trigger.ps1"

run_powershell_script() {
  script_path="$1"
  error_message="$2"

  if command -v pwsh >/dev/null 2>&1; then
    pwsh -NoProfile -ExecutionPolicy Bypass -File "$script_path"
    return
  fi

  if command -v powershell.exe >/dev/null 2>&1; then
    powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$script_path"
    return
  fi

  if command -v powershell >/dev/null 2>&1; then
    powershell -NoProfile -ExecutionPolicy Bypass -File "$script_path"
    return
  fi

  echo "$error_message" >&2
  exit 1
}

run_powershell_script "$sync_script" "PowerShell wurde nicht gefunden. Der Web-Asset-Sync konnte vor dem Commit nicht ausgefuehrt werden."
run_powershell_script "$trigger_script" "PowerShell wurde nicht gefunden. Der Redeploy-Trigger konnte vor dem Commit nicht aktualisiert werden."

git -C "$repo_root" add -- \
  app/src/main/assets/index.html \
  app/src/main/assets/manifest.webmanifest \
  app/src/main/assets/sw.js \
  app/src/main/assets/icons \
  docs/index.html \
  docs/manifest.webmanifest \
  docs/redeploy-trigger.txt \
  docs/sw.js \
  docs/icons \
  docs/.nojekyll \
  docs/README-GitHub-Pages.txt
